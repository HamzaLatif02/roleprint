# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/roleprint

# ── Cache / Queue ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Email ─────────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx

# ── Scraper ───────────────────────────────────────────────────────────────────
SCRAPE_INTERVAL_HOURS=6

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
